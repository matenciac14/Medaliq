generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(ATHLETE)
  password      String?
  emailVerified DateTime?
  config        Json      @default("{}")   // UserConfig — controla features y datos del usuario
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       HealthProfile?
  goals         Goal[]
  trainingPlans TrainingPlan[]
  sessionLogs   SessionLog[]
  checkIns      WeeklyCheckIn[]
  nutritionPlan NutritionPlan?
  coachOf       CoachAthlete[] @relation("CoachRelation")
  coachedBy     CoachAthlete[] @relation("AthleteRelation")
}

enum UserRole {
  ATHLETE
  COACH
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── COACH <> ATHLETE ───────────────────────────────────────────────────────

model CoachAthlete {
  id        String   @id @default(cuid())
  coachId   String
  athleteId String
  createdAt DateTime @default(now())

  coach   User @relation("CoachRelation", fields: [coachId], references: [id])
  athlete User @relation("AthleteRelation", fields: [athleteId], references: [id])

  @@unique([coachId, athleteId])
}

// ─── PERFIL DE SALUD ────────────────────────────────────────────────────────

model HealthProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  age            Int
  heightCm       Float
  weightKg       Float
  weightGoalKg   Float?
  hrResting      Int?
  hrMax          Int?
  altitudeMeters Int?
  injuries       String[]
  conditions     String[]
  medications    String[]
  sleepHoursAvg  Float?
  sleepScoreAvg  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── OBJETIVO ───────────────────────────────────────────────────────────────

model Goal {
  id             String     @id @default(cuid())
  userId         String
  type           GoalType
  raceDate       DateTime?
  targetTimeSecs Int?
  targetWeightKg Float?
  description    String?
  status         GoalStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlans TrainingPlan[]
}

enum GoalType {
  RACE_5K
  RACE_10K
  RACE_HALF_MARATHON
  RACE_MARATHON
  RACE_TRIATHLON
  RACE_CYCLING
  BODY_RECOMPOSITION
  WEIGHT_LOSS
  GENERAL_FITNESS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// ─── PLAN DE ENTRENAMIENTO ──────────────────────────────────────────────────

model TrainingPlan {
  id          String     @id @default(cuid())
  userId      String
  goalId      String?
  name        String
  totalWeeks  Int
  startDate   DateTime
  endDate     DateTime
  status      PlanStatus @default(ACTIVE)
  hrZones     Json
  generatedBy PlanSource @default(AI)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal  Goal?      @relation(fields: [goalId], references: [id])
  weeks PlanWeek[]
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum PlanSource {
  AI
  COACH
  AI_COACH_APPROVED
}

model PlanWeek {
  id               String   @id @default(cuid())
  planId           String
  weekNumber       Int
  phase            Phase
  volumeKm         Float?
  focusDescription String?
  isRecoveryWeek   Boolean  @default(false)
  startDate        DateTime
  endDate          DateTime

  plan     TrainingPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  sessions PlannedSession[]

  @@unique([planId, weekNumber])
}

enum Phase {
  BASE
  DESARROLLO
  ESPECIFICO
  AFINAMIENTO
}

model PlannedSession {
  id          String      @id @default(cuid())
  weekId      String
  dayOfWeek   Int
  type        SessionType
  durationMin Int
  zoneTarget  String?
  structure   String?
  detailText  String?
  date        DateTime

  week PlanWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  log  SessionLog?
}

enum SessionType {
  RODAJE_Z2
  FARTLEK
  TEMPO
  INTERVALOS
  TIRADA_LARGA
  FUERZA
  CICLA
  NATACION
  DESCANSO
  TEST
  SIMULACRO
  OTRO
}

// ─── REGISTRO DE SESIÓN ─────────────────────────────────────────────────────

model SessionLog {
  id               String   @id @default(cuid())
  userId           String
  plannedSessionId String?  @unique
  completedAt      DateTime @default(now())
  rpe              Int?
  hrAvg            Int?
  hrMax            Int?
  distanceKm       Float?
  durationMin      Int?
  notes            String?
  garminActivityId String?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedSession PlannedSession? @relation(fields: [plannedSessionId], references: [id])
}

// ─── CHECK-IN SEMANAL ───────────────────────────────────────────────────────

model WeeklyCheckIn {
  id                   String   @id @default(cuid())
  userId               String
  weekNumber           Int
  recordedAt           DateTime @default(now())
  weightKg             Float?
  hrResting            Int?
  sleepHours           Float?
  sleepScore           Float?
  hardestSessionRpe    Int?
  dietAdherencePct     Int?
  painFlag             Boolean  @default(false)
  energyLevel          Int?
  notes                String?
  adjustmentsTriggered String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
}

// ─── PLAN NUTRICIONAL ───────────────────────────────────────────────────────

model NutritionPlan {
  id             String   @id @default(cuid())
  userId         String   @unique
  tdee           Int
  targetKcalHard Int
  targetKcalEasy Int
  targetKcalRest Int
  proteinG       Int
  carbsHardG     Int
  carbsEasyG     Int
  fatG           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
