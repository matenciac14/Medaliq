generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(ATHLETE)
  password      String?
  emailVerified DateTime?
  config        Json      @default("{}")   // UserConfig — controla features y datos del usuario
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  profile           HealthProfile?
  goals             Goal[]
  trainingPlans     TrainingPlan[]
  sessionLogs       SessionLog[]
  checkIns          WeeklyCheckIn[]
  nutritionPlan     NutritionPlan?
  coachOf           CoachAthlete[]    @relation("CoachRelation")
  coachedBy         CoachAthlete[]    @relation("AthleteRelation")

  // Gym feature
  exercises          Exercise[]        @relation("CoachExercises")
  workoutTemplates   WorkoutTemplate[] @relation("CoachTemplates")
  coachAssignments   AssignedWorkout[] @relation("CoachAssignments")
  athleteAssignments AssignedWorkout[] @relation("AthleteAssignments")
  gymSessions        GymSession[]

  // Marketplace
  coachProfile       CoachProfile?

  // Métricas diarias
  dailyLogs          DailyLog[]
}

enum UserRole {
  ATHLETE
  COACH
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── COACH <> ATHLETE ───────────────────────────────────────────────────────

model CoachAthlete {
  id        String   @id @default(cuid())
  coachId   String
  athleteId String
  createdAt DateTime @default(now())

  coach   User @relation("CoachRelation", fields: [coachId], references: [id])
  athlete User @relation("AthleteRelation", fields: [athleteId], references: [id])

  @@unique([coachId, athleteId])
}

// ─── PERFIL DE SALUD ────────────────────────────────────────────────────────

model HealthProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  dateOfBirth    DateTime? @db.Date
  age            Int
  heightCm       Float
  weightKg       Float
  weightGoalKg   Float?
  hrResting      Int?
  hrMax          Int?
  altitudeMeters Int?
  injuries       String[]
  conditions     String[]
  medications    String[]
  sleepHoursAvg  Float?
  sleepScoreAvg  Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── OBJETIVO ───────────────────────────────────────────────────────────────

model Goal {
  id             String     @id @default(cuid())
  userId         String
  type           GoalType
  raceDate       DateTime?
  targetTimeSecs Int?
  targetWeightKg Float?
  description    String?
  status         GoalStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingPlans TrainingPlan[]
}

enum GoalType {
  RACE_5K
  RACE_10K
  RACE_HALF_MARATHON
  RACE_MARATHON
  RACE_TRIATHLON
  RACE_CYCLING
  BODY_RECOMPOSITION
  WEIGHT_LOSS
  GENERAL_FITNESS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// ─── PLAN DE ENTRENAMIENTO ──────────────────────────────────────────────────

model TrainingPlan {
  id          String     @id @default(cuid())
  userId      String
  goalId      String?
  name        String
  totalWeeks  Int
  startDate   DateTime
  endDate     DateTime
  status      PlanStatus @default(ACTIVE)
  hrZones     Json
  generatedBy PlanSource @default(AI)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal  Goal?      @relation(fields: [goalId], references: [id])
  weeks PlanWeek[]
}

enum PlanStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ABANDONED
}

enum PlanSource {
  AI
  COACH
  AI_COACH_APPROVED
}

model PlanWeek {
  id               String   @id @default(cuid())
  planId           String
  weekNumber       Int
  phase            Phase
  volumeKm         Float?
  focusDescription String?
  isRecoveryWeek   Boolean  @default(false)
  startDate        DateTime
  endDate          DateTime

  plan     TrainingPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  sessions PlannedSession[]

  @@unique([planId, weekNumber])
}

enum Phase {
  BASE
  DESARROLLO
  ESPECIFICO
  AFINAMIENTO
}

model PlannedSession {
  id          String      @id @default(cuid())
  weekId      String
  dayOfWeek   Int
  type        SessionType
  durationMin Int
  zoneTarget  String?
  structure   String?
  detailText  String?
  coachNote   String?
  date        DateTime

  week PlanWeek    @relation(fields: [weekId], references: [id], onDelete: Cascade)
  log  SessionLog?
}

enum SessionType {
  RODAJE_Z2
  FARTLEK
  TEMPO
  INTERVALOS
  TIRADA_LARGA
  FUERZA
  CICLA
  NATACION
  DESCANSO
  TEST
  SIMULACRO
  OTRO
}

// ─── REGISTRO DE SESIÓN ─────────────────────────────────────────────────────

model SessionLog {
  id               String   @id @default(cuid())
  userId           String
  plannedSessionId String?  @unique
  completedAt      DateTime @default(now())
  rpe              Int?
  hrAvg            Int?
  hrMax            Int?
  distanceKm       Float?
  durationMin      Int?
  notes            String?
  garminActivityId String?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedSession PlannedSession? @relation(fields: [plannedSessionId], references: [id])
}

// ─── MÉTRICAS DIARIAS ───────────────────────────────────────────────────────

model DailyLog {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  weightKg    Float?
  hrResting   Int?
  sleepHours  Float?
  energyLevel Int?     // 1-5
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// ─── CHECK-IN SEMANAL ───────────────────────────────────────────────────────

model WeeklyCheckIn {
  id                   String   @id @default(cuid())
  userId               String
  weekNumber           Int
  recordedAt           DateTime @default(now())
  weightKg             Float?
  hrResting            Int?
  sleepHours           Float?
  sleepScore           Float?
  hardestSessionRpe    Int?
  dietAdherencePct     Int?
  painFlag             Boolean  @default(false)
  energyLevel          Int?
  notes                String?
  adjustmentsTriggered String[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
}

// ─── GYM COACH FEATURE ──────────────────────────────────────────────────────

model Exercise {
  id           String   @id @default(cuid())
  coachId      String?  // null = librería global, string = ejercicio personalizado del coach
  name         String
  muscleGroups String[] // ["QUADRICEPS", "GLUTES", "HAMSTRINGS"]
  equipment    EquipmentType @default(BARBELL)
  category     ExerciseCategory @default(COMPOUND)
  description  String?
  tips         String?
  imageUrl     String?
  isGlobal     Boolean  @default(false) // true = librería base de Medaliq

  coach            User?             @relation("CoachExercises", fields: [coachId], references: [id])
  workoutExercises WorkoutExercise[]

  createdAt DateTime @default(now())
}

enum EquipmentType {
  BARBELL
  DUMBBELL
  MACHINE
  CABLE
  SMITH
  BODYWEIGHT
  KETTLEBELL
  BAND
  OTHER
}

enum ExerciseCategory {
  COMPOUND
  ISOLATION
  CARDIO
  STRETCH
  FUNCTIONAL
}

model WorkoutTemplate {
  id          String  @id @default(cuid())
  coachId     String
  name        String
  description String?
  goal        String? // "HYPERTROPHY", "STRENGTH", "TONING", "FUNCTIONAL"
  level       String? // "BEGINNER", "INTERMEDIATE", "ADVANCED"
  daysPerWeek Int     @default(6)
  isActive    Boolean @default(true)

  coach       User             @relation("CoachTemplates", fields: [coachId], references: [id])
  days        WorkoutDay[]
  assignments AssignedWorkout[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkoutDay {
  id           String   @id @default(cuid())
  templateId   String
  dayOfWeek    Int      // 1=Lunes … 7=Domingo
  label        String   // "Lunes — Cuádriceps y Gemelos"
  muscleGroups String[]
  isRestDay    Boolean  @default(false)
  warmupNotes  String?
  cardioNotes  String?
  order        Int      @default(0)

  template  WorkoutTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id           String      @id @default(cuid())
  dayId        String
  exerciseId   String
  order        Int
  sets         Int         // 4
  repsScheme   String      // "12-15-18-20" | "12" | "hasta el fallo"
  restSeconds  Int?        // 90
  notes        String?
  setType      SetType     @default(NORMAL)
  supersetWith String?     // id de otro WorkoutExercise

  day      WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
  exercise Exercise   @relation(fields: [exerciseId], references: [id])
  setLogs  SetLog[]
}

enum SetType {
  NORMAL
  SUPERSET
  BISERIE
  DROPSET
  CIRCUIT
}

model AssignedWorkout {
  id            String    @id @default(cuid())
  templateId    String
  athleteId     String
  coachId       String
  startDate     DateTime
  endDate       DateTime?
  weeksDuration Int?
  isActive      Boolean   @default(true)
  notes         String?

  template    WorkoutTemplate @relation(fields: [templateId], references: [id])
  athlete     User            @relation("AthleteAssignments", fields: [athleteId], references: [id])
  coach       User            @relation("CoachAssignments", fields: [coachId], references: [id])
  gymSessions GymSession[]

  createdAt DateTime @default(now())
}

model GymSession {
  id                String   @id @default(cuid())
  athleteId         String
  assignedWorkoutId String
  dayOfWeek         Int
  date              DateTime
  durationMin       Int?
  rpe               Int?     // 1-10
  notes             String?
  completed         Boolean  @default(false)

  athlete         User            @relation(fields: [athleteId], references: [id])
  assignedWorkout AssignedWorkout @relation(fields: [assignedWorkoutId], references: [id])
  setLogs         SetLog[]

  createdAt DateTime @default(now())
}

model SetLog {
  id                String  @id @default(cuid())
  sessionId         String
  workoutExerciseId String
  setNumber         Int
  weightKg          Float?
  repsCompleted     Int?
  completed         Boolean @default(false)
  notes             String?

  session         GymSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id])
}

// ─── MARKETPLACE DE COACHES ─────────────────────────────────────────────────

model CoachProfile {
  id             String   @id @default(cuid())
  coachId        String   @unique
  slug           String   @unique   // "carlos-entrenador"
  bio            String?
  avatarUrl      String?
  headline       String?            // "Especialista en media maratón y recomposición"
  specialties    String[]           // ["RUNNING", "GYM", "CYCLING", "TRIATHLON", "FUNCTIONAL"]
  city           String?
  country        String   @default("CO")
  whatsapp       String?
  instagram      String?
  yearsExp       Int?
  certifications String[]
  isPublic       Boolean  @default(false)

  coach    User           @relation(fields: [coachId], references: [id])
  programs CoachProgram[]
  posts    CoachPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoachProgram {
  id            String   @id @default(cuid())
  profileId     String
  name          String   // "Plan Media Maratón — 18 semanas"
  description   String?
  sport         String   // "RUNNING", "GYM", "CYCLING", "TRIATHLON", "FUNCTIONAL"
  level         String   // "BEGINNER", "INTERMEDIATE", "ADVANCED"
  durationWeeks Int?
  priceMonth    Float?   // USD/mes
  currency      String   @default("USD")
  includes      String[] // ["Plan personalizado", "Check-in semanal", "Chat directo"]
  isActive      Boolean  @default(true)

  profile CoachProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model CoachPost {
  id        String   @id @default(cuid())
  profileId String
  type      PostType
  title     String
  body      String
  imageUrl  String?
  tags      String[]
  isPublic  Boolean  @default(true)

  profile CoachProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

enum PostType {
  TIP
  ROUTINE_SHOWCASE
  ACHIEVEMENT
  ANNOUNCEMENT
}

// ─── PLAN NUTRICIONAL ───────────────────────────────────────────────────────

model NutritionPlan {
  id             String   @id @default(cuid())
  userId         String   @unique
  tdee           Int
  targetKcalHard Int
  targetKcalEasy Int
  targetKcalRest Int
  proteinG       Int
  carbsHardG     Int
  carbsEasyG     Int
  fatG           Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
